# Mini-Aladdin Environment Variables
# Copy this to .env and fill in your values

# ── Alpaca (Required for paper/live trading) ──────────────────────────────────
# Get free keys at https://alpaca.markets → Paper Trading dashboard
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true   # Keep as "true" for paper trading. Set "false" ONLY for live.

# ── Telegram Alerts (Required for phone notifications) ────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy the token below
# Step 2: Add bot to your group → get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── OpenAI (Optional — for AI analysis features) ──────────────────────────────
# Get key at https://platform.openai.com/api-keys
# System works without this — falls back to rule-based analysis
OPENAI_API_KEY=

# ── Polygon.io (Optional — upgrade from yfinance for better data) ─────────────
# Free tier at https://polygon.io
POLYGON_API_KEY=
